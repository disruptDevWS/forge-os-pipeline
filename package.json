{
  "name": "forge-os-pipeline",
  "version": "1.0.0",
  "description": "SEO audit pipeline toolkit. Dashboard → Supabase Edge Functions → HTTP server → shell orchestrator → TypeScript phase generators → Supabase.",
  "type": "module",
  "main": "dist/pipeline-server-standalone.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/pipeline-server-standalone.js",
    "dev": "tsx src/pipeline-server-standalone.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "sync": "tsx scripts/sync-to-dashboard.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@supabase/supabase-js": "^2.97.0",
    "csv-parse": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.0.18",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
